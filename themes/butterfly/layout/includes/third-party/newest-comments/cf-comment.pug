- var cfConfig = theme['cf-comment'] || {}
- var server = cfConfig.server || ''
- var siteKey = cfConfig.site_key || 'default'
- var newestConfig = theme.newest_comments || {}
- var showAvatar = newestConfig.avatar !== false
- var storageTime = newestConfig.storage || 10
- var commentLimit = newestConfig.limit || 6
- var lazyloadEnabled = theme.lazyload && theme.lazyload.enable

script.
  (function() {
    const changeContent = (content) => {
      if (content === '') return content

      content = content.replace(/<img.*?src="(.*?)"?[^\>]+>/ig, '[#{_p("aside.card_newest_comments.image")}]')
      content = content.replace(/<a[^>]+?href=["']?([^"']+)["']?[^>]*>([^<]+)<\/a>/gi, '[#{_p("aside.card_newest_comments.link")}]')
      content = content.replace(/<pre><code>.*?<\/pre>/gi, '[#{_p("aside.card_newest_comments.code")}]')
      content = content.replace(/<[^>]+>/g, '')

      if (content.length > 150) {
        content = content.substring(0, 150) + '...'
      }
      return content
    }

    const generateHtml = array => {
      let result = ''

      if (array.length) {
        for (let i = 0; i < array.length; i++) {
          // 使用 page_url 来链接到文章，如果没有则使用 area_key
          const pageUrl = array[i].page_url ? '/' + array[i].page_url : '/' + array[i].area_key.replace(/-/g, '/') + '.html'
          const commentUrl = pageUrl + '#cf-comment-wrap'

          result += '<div class=\'aside-list-item\'>'

          if (#{showAvatar ? 'true' : 'false'}) {
            // cf-comment 暂不支持头像，使用默认头像
            const imgAttr = '#{lazyloadEnabled ? "data-lazy-src" : "src"}'
            result += `<a href='${commentUrl}' class='thumbnail'><img ${imgAttr}='https://cravatar.cn/avatar/?d=mp&s=48' alt='用户'></a>`
          }

          result += `<div class='content'>
          <a class='comment' href='${commentUrl}' title='${array[i].preview}'>${changeContent(array[i].preview)}</a>
          <div class='name'><span>${array[i].area_name} / </span><time datetime="${array[i].created_at}">${btf.diffDate(array[i].created_at, true)}</time></div>
          </div></div>`
        }
      } else {
        result += '#{_p("aside.card_newest_comments.zero")}'
      }

      let $dom = document.querySelector('#card-newest-comments .aside-list')
      if ($dom) {
        $dom.innerHTML = result
        window.lazyLoadInstance && window.lazyLoadInstance.update()
        window.pjax && window.pjax.refresh($dom)
      }
    }

    const getComment = async () => {
      try {
        const apiUrl = '#{server}/api/#{siteKey}/latest-comments?limit=#{commentLimit}'
        const res = await fetch(apiUrl, { method: 'GET' })
        const result = await res.json()

        if (result.success && result.data) {
          const cfCommentArray = result.data.map(e => ({
            'preview': e.preview || e.content,
            'area_key': e.area_key,
            'area_name': e.area_name || e.area_key,
            'page_url': e.page_url || '',
            'created_at': e.created_at
          }))

          const storageDays = #{storageTime} / (60 * 24)
          saveToLocal.set('cf-comment-newest-comments', JSON.stringify(cfCommentArray), storageDays)
          generateHtml(cfCommentArray)
        } else {
          throw new Error(result.message || '获取评论失败')
        }
      } catch (e) {
        console.error('CF-Comment newest comments error:', e)
        const $dom = document.querySelector('#card-newest-comments .aside-list')
        if ($dom) {
          $dom.innerHTML = '#{_p("aside.card_newest_comments.error")}'
        }
      }
    }

    const newestCommentInit = () => {
      const $dom = document.querySelector('#card-newest-comments .aside-list')
      if (!$dom) return

      const data = saveToLocal.get('cf-comment-newest-comments')
      if (data) {
        try {
          generateHtml(JSON.parse(data))
        } catch (e) {
          console.error('CF-Comment: 缓存数据解析失败，重新获取', e)
          localStorage.removeItem('cf-comment-newest-comments')
          getComment()
        }
      } else {
        getComment()
      }
    }

    // 确保 DOM 就绪后执行
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', newestCommentInit)
    } else {
      newestCommentInit()
    }

    // PJAX 支持
    document.addEventListener('pjax:complete', newestCommentInit)
  })()
