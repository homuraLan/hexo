//- CF-Comment 评论系统集成
//- 检查cf-comment是否在评论系统列表中（忽略大小写）
- var isCfCommentInUse = theme.comments.use.some(function(item) { return item.toLowerCase() === 'cf-comment'; })

if isCfCommentInUse
  //- 评论系统切换逻辑所需变量
  - var firstCommentSystem = (theme.comments.use[0] || '').toLowerCase()
  - var isLazyloadEnabled = theme.comments.lazyload === true ? 'true' : 'false'

  script.
    (()=>{
      function loadCfComment() {
        const cfCommentWrap = document.getElementById('cf-comment-wrap');
        if (!cfCommentWrap) {
          console.error('CF-Comment: 找不到评论容器');
          return;
        }

        // 从data属性读取配置（支持PJAX动态更新）
        const dataEl = document.getElementById('cf-comment-data');
        if (!dataEl) {
          console.error('CF-Comment: 找不到配置数据');
          return;
        }

        const server = dataEl.dataset.server;
        const siteKey = dataEl.dataset.siteKey;
        const areaKey = dataEl.dataset.areaKey;
        const cfTheme = dataEl.dataset.theme;
        const lang = dataEl.dataset.lang;
        const areaName = encodeURIComponent(dataEl.dataset.areaName);
        const pageUrl = encodeURIComponent(dataEl.dataset.pageUrl);

        // 调试信息
        console.log('CF-Comment 加载:', { areaKey, areaName: decodeURIComponent(areaName), pageUrl: decodeURIComponent(pageUrl) });

        // 清空容器内容，避免重复加载
        cfCommentWrap.innerHTML = '';

        // 确定主题色
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const resolvedTheme = cfTheme === 'auto' ? (isDark ? 'dark' : 'light') : cfTheme;

        // 构建iframe URL - 支持自动创建评论区，page_url字段存储文章URL
        const iframeUrl = server + '/embed/area/' + areaKey + '?theme=' + resolvedTheme + '&lang=' + lang + '&auto_create=1&site_key=' + siteKey + '&area_name=' + areaName + '&page_url=' + pageUrl;
        
        // 创建iframe
        cfCommentWrap.innerHTML = `
          <iframe id="cf-comment-iframe"
                  src="${iframeUrl}"
                  width="100%"
                  frameborder="0"
                  scrolling="auto"
                  style="border: none; height: 300px; min-height: 200px; max-height: 800px; transition: height 0.3s ease;"
                  title="CF-Comment评论系统">
          </iframe>
        `;
        
        // 设置iframe加载事件
        const iframe = document.getElementById('cf-comment-iframe');
        if (iframe) {
          iframe.onload = function() {
            // iframe加载完成后，尝试获取内容高度进行自适应
            setTimeout(() => {
              try {
                // 如果cf-comment支持，会通过postMessage发送高度信息
                iframe.contentWindow.postMessage({ type: 'getHeight' }, server);
              } catch (e) {
                // 跨域访问限制，正常情况
              }
            }, 1000);
          };
          iframe.onerror = function() {
            console.error('CF-Comment: iframe加载失败');
            cfCommentWrap.innerHTML = '<p style="text-align: center; color: #999; padding: 20px;">评论加载失败，请刷新页面重试</p>';
          };
        }
      }
      
      // 主题切换支持
      function cfCommentChangeMode(theme) {
        const iframe = document.getElementById('cf-comment-iframe');
        if (!iframe) return;
        
        const cfTheme = theme === 'dark' ? 'dark' : 'light';
        const currentUrl = new URL(iframe.src);
        currentUrl.searchParams.set('theme', cfTheme);
        iframe.src = currentUrl.toString();
      }
      
      // 注册主题切换回调
      btf.addModeChange('cf-comment', cfCommentChangeMode);
      
      // 监听iframe消息，动态调整高度
      const messageHandler = function(event) {
        // 检查消息来源
        const dataEl = document.getElementById('cf-comment-data');
        const server = dataEl ? dataEl.dataset.server : '';
        if (!server || event.origin !== server) {
          return;
        }
        
        const iframe = document.getElementById('cf-comment-iframe');
        if (!iframe) return;
        
        // 处理高度调整消息
        const maxHeight = 800;
        if (event.data && typeof event.data === 'object') {
          if (event.data.type === 'resize' && event.data.height) {
            // cf-comment发送的标准resize消息
            iframe.style.height = Math.min(Math.max(event.data.height, 200), maxHeight) + 'px';
          } else if (event.data.height && !event.data.type) {
            // 兼容其他格式的高度消息
            iframe.style.height = Math.min(Math.max(event.data.height, 200), maxHeight) + 'px';
          } else if (typeof event.data === 'number') {
            // 纯数字高度消息
            iframe.style.height = Math.min(Math.max(event.data, 200), maxHeight) + 'px';
          }
        }
      };
      
      // 移除之前的事件监听器（避免重复绑定）
      window.removeEventListener('message', window.cfCommentMessageHandler);
      window.addEventListener('message', messageHandler);
      window.cfCommentMessageHandler = messageHandler;
      
      // 多评论系统切换逻辑
      const isCfCommentFirst = '!{firstCommentSystem}' === 'cf-comment';
      const isLazyload = '!{isLazyloadEnabled}' === 'true';

      if (isCfCommentFirst || isLazyload) {
        if (isLazyload) {
          btf.loadComment(document.getElementById('cf-comment-wrap'), loadCfComment);
        } else {
          loadCfComment();
        }
      } else {
        window.loadOtherComment = function() {
          loadCfComment();
        }
      }

      // PJAX支持：页面切换时重新加载评论
      document.addEventListener('pjax:complete', function() {
        loadCfComment();
      });
    })()
