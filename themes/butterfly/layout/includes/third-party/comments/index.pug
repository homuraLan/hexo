- let defaultComment = theme.comments.use[0]
hr
#post-comment
  .comment-head
    .comment-headline
      i.fas.fa-comments.fa-fw
      span= ' ' + _p('comment')
    
    if theme.comments.use.length > 1
      #comment-switch
        span.first-comment=defaultComment
        span.switch-btn
        span.second-comment=theme.comments.use[1]


  .comment-wrap
    each name in theme.comments.use
      div
        case name
          when 'Disqus'
            #disqus_thread
          when 'Valine'
            #vcomment.vcomment
          when 'Disqusjs'
            #disqusjs
          when 'Livere'
            #lv-container(data-id="city" data-uid=theme.livere.uid)
          when 'Gitalk'
            #gitalk-container
          when 'Utterances'
            #utterances-wrap
          when 'Twikoo'
            #twikoo-wrap
          when 'Waline'
            #waline-wrap
          when 'Giscus'
            #giscus-wrap
          when 'Facebook Comments'
            .fb-comments(data-colorscheme = theme.display_mode === 'dark' ? 'dark' : 'light'
                        data-numposts= theme.facebook_comments.pageSize || 10
                        data-order-by= theme.facebook_comments.order_by || 'social'
                        data-width="100%")
          when 'Remark42'
            #remark42
          when 'Artalk'
            #artalk-wrap
          when 'cf-comment'
            - var cfConfig = theme['cf-comment'] || {}
            - var cfServer = cfConfig.server || ''
            - var cfSiteKey = cfConfig.site_key || 'default'
            - var cfAreaKey = page.comment_id || page.path.replace(/\//g, '-').replace(/\.html$/, '').replace(/^-|-$/g, '') || 'default'
            - var cfTheme = cfConfig.theme || 'auto'
            - var cfLang = cfConfig.lang || 'zh-CN'
            - var cfPageTitle = page.title || '评论区'
            - var cfPageUrl = page.path || ''
            #cf-comment-data(
              data-server=cfServer
              data-site-key=cfSiteKey
              data-area-key=cfAreaKey
              data-theme=cfTheme
              data-lang=cfLang
              data-area-name=cfPageTitle
              data-page-url=cfPageUrl
              style="display:none"
            )
            #cf-comment-wrap
          when 'Cf-Comment'
            - var cfConfig = theme['cf-comment'] || {}
            - var cfServer = cfConfig.server || ''
            - var cfSiteKey = cfConfig.site_key || 'default'
            - var cfAreaKey = page.comment_id || page.path.replace(/\//g, '-').replace(/\.html$/, '').replace(/^-|-$/g, '') || 'default'
            - var cfTheme = cfConfig.theme || 'auto'
            - var cfLang = cfConfig.lang || 'zh-CN'
            - var cfPageTitle = page.title || '评论区'
            - var cfPageUrl = page.path || ''
            #cf-comment-data(
              data-server=cfServer
              data-site-key=cfSiteKey
              data-area-key=cfAreaKey
              data-theme=cfTheme
              data-lang=cfLang
              data-area-name=cfPageTitle
              data-page-url=cfPageUrl
              style="display:none"
            )
            #cf-comment-wrap
