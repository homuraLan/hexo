extends includes/layout.pug

block content
  #post
    if top_img === false
      include includes/header/post-info.pug

    article#article-container.post-content!=page.content
    include includes/post/post-copyright.pug
    .tag_share
      if (theme.post_meta.post.tags)
        .post-meta__tag-list
          each item, index in page.tags.data
            a(href=url_for(item.path)).post-meta__tags
              .tags-punctuation
                svg.faa-tada.icon(style="height:1.1em;width:1.1em;fill:currentColor;position:relative;top:2px;margin-right:3px" aria-hidden="true")
                  use(xlink:href='#icon-sekuaibiaoqian')
              =item.name
      //- include includes/third-party/share/index.pug
        
    if theme.reward.enable && theme.reward.QR_code
      !=partial('includes/post/reward', {}, {cache: true})

    //- ad
    if theme.ad && theme.ad.post
      .ads-wrap!=theme.ad.post

    if theme.post_pagination
      include includes/pagination.pug
    if theme.related_post && theme.related_post.enable
      != related_posts(page,site.posts)

    //- 详细调试信息
    script.
      console.log('🔍 评论系统调试开始');
      console.log('🔍 page.comments:', '#{page.comments}');
      console.log('🔍 theme.comments:', !{JSON.stringify(theme.comments || {})});
      console.log('🔍 条件1 - page.comments !== false:', #{page.comments} !== false);
      console.log('🔍 条件2 - theme.comments存在:', !{theme.comments ? 'true' : 'false'});
      console.log('🔍 条件3 - theme.comments.use存在:', !{(theme.comments && theme.comments.use) ? 'true' : 'false'});
      if (!{theme.comments && theme.comments.use}) {
        console.log('🔍 theme.comments.use内容:', !{JSON.stringify(theme.comments.use)});
      }
      console.log('🔍 最终条件判断结果:', (!{page.comments} !== false) && !{theme.comments ? 'true' : 'false'} && !{(theme.comments && theme.comments.use) ? 'true' : 'false'});

    if page.comments !== false && theme.comments && theme.comments.use
      script.
        console.log('✅ 评论系统条件判断通过，开始加载');
      - var commentsJsLoad = true
      !=partial('includes/third-party/comments/index', {}, {cache: true})
    else
      script.
        console.log('❌ 评论系统条件判断失败');
        console.log('❌ 失败原因分析:');
        console.log('  - page.comments !== false:', (!{page.comments} !== false));
        console.log('  - theme.comments存在:', !{theme.comments ? 'true' : 'false'});
        console.log('  - theme.comments.use存在:', !{(theme.comments && theme.comments.use) ? 'true' : 'false'});
      